services:
  web-booking:
    build:
      context: ./web/booking
      target: dev
    image: stay-hr-web-booking:dev
    environment:
      NODE_ENV: development
      WATCHPACK_POLLING: "true"
      HOSTNAME: "0.0.0.0"
    command: ["sh", "-c", "npm install && npm run dev -- --hostname 0.0.0.0 --port 3000"]
    volumes:
      - ./web/booking:/app
      - web_booking_node_modules:/app/node_modules

  web-reception:
    build:
      context: ./web/reception
      target: dev
    image: stay-hr-web-reception:dev
    environment:
      NODE_ENV: development
      WATCHPACK_POLLING: "true"
    volumes:
      - ./web/reception:/app
      - web_reception_node_modules:/app/node_modules

volumes:
  web_booking_node_modules:
  web_reception_node_modules:
