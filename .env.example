# Cloudflare DNS: see scripts/.env.example and ./scripts/cloudflare_dns_upsert.sh
# Hosts: api.stay.hr, admin.stay.hr (proxied A → Traefik → django)

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.stay.hr,admin.stay.hr,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.stay.hr,https://admin.stay.hr

# Database (shared PostGIS — /opt/stacks/data, container: postgis, network: postgis)
DB_HOST=postgis
DB_PORT=5432
DB_NAME=stay_platform_db
DB_USER=stay
DB_PASSWORD=change-me
DB_CONN_MAX_AGE=60

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
