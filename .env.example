# Cloudflare DNS: see scripts/.env.example and ./scripts/cloudflare_dns_upsert.sh
# Hosts: api.stay.hr, admin.stay.hr (proxied A → Traefik → django)
CF_DNS_API_TOKEN=
STAY_SERVER_IP=
CLOUDFLARE_ZONE_STAY=stay.hr
STAY_API_INTERNAL_URL=http://stay-django:8000
STAY_PUBLIC_API_URL=https://api.stay.hr
# Public booking web BFF — ApiApplication with public:read + reservations:create
STAY_BOOKING_API_TOKEN=

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.stay.hr,admin.stay.hr,*.stay.hr,app.stay.hr,stay-django,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.stay.hr,https://admin.stay.hr,https://app.stay.hr,https://*.stay.hr

# Database (shared PostGIS — /opt/stacks/data, container: postgis, network: postgis)
DB_HOST=postgis
DB_PORT=5432
DB_NAME=stay_platform_db
DB_USER=stay
DB_PASSWORD=change-me
DB_CONN_MAX_AGE=60

# Uzorita legacy read-only source (migrate_uzorita_legacy / validate_uzorita_migration)
# UZORITA_DB_NAME=uzorita_db
# UZORITA_DB_USER=postgres
# UZORITA_DB_PASSWORD=
# UZORITA_DB_HOST=localhost
# UZORITA_DB_PORT=5432
# UZORITA_EVISITOR_ENABLED=true
# UZORITA_EVISITOR_ENV=test
# UZORITA_EVISITOR_BASE_URL=https://www.evisitor.hr/testApi
# UZORITA_EVISITOR_USERNAME=
# UZORITA_EVISITOR_PASSWORD=
# UZORITA_EVISITOR_API_KEY=
# UZORITA_EVISITOR_FACILITY_CODE=

# Demo eVisitor bootstrap (seed_evisitor_config — test HTZ okolina)
# DEMO_EVISITOR_USERNAME=
# DEMO_EVISITOR_PASSWORD=
# DEMO_EVISITOR_API_KEY=
# DEMO_EVISITOR_FACILITY_CODE=
# DEMO_EVISITOR_BASE_URL=https://www.evisitor.hr/testApi
# DEMO_EVISITOR_ENV=test
# DEMO_EVISITOR_ENABLED=true

# Channex — per-tenant credentials live in Django admin (Integration configs), not .env.
# Bootstrap only (optional one-shot seed): export CHANNEX_* then run sync_channex_credentials --tenant-slug uzorita
# CHANNEX_PROPERTY_ID=
# CHANNEX_API_KEY=
# CHANNEX_WEBHOOK_SECRET=
# See docs/operations/channex-credentials-migration.md

# Smoobu — removed from stay.hr (migration 0017). Uzorita uses Channex. Do not put in .env.

# Meta / WhatsApp Cloud API — app stay.hr (Facebook Login NOT required)
# META_APP_ID=                    # Settings → Basic → App ID (reference only)
# META_APP_CONTACT_EMAIL=info@stay.hr
# META_PRIVACY_POLICY_URL=https://finestar.hr/privacy
# META_TERMS_URL=https://stay.hr/terms
# WHATSAPP_APP_SECRET=            # Settings → Basic → App secret (Show)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=  # random string; same in Meta webhook config
# WHATSAPP_API_VERSION=v23.0
# WHATSAPP_ACCESS_TOKEN=          # System User token (Meta Graph API) — never commit
# WHATSAPP_WABA_ID=               # optional; fallback for template sync/create CLI
# Webhook callback: https://api.stay.hr/api/v1/integrations/whatsapp/webhook/
# Integration identity (phone_number_id, display_phone_number, waba_id) in Django admin → Integration configs.
# Platform default number: docker compose exec django python manage.py seed_platform_whatsapp_config
# Hotel tenant number: docker compose exec django python manage.py seed_uzorita_whatsapp_config

# Fernet key: IntegrationConfig (eVisitor) + encrypted API device tokens in admin
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# STAY_INTEGRATION_FERNET_KEY=

# Firebase FCM (Admin SDK service account — mount in docker-compose, never commit JSON)
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
# FIREBASE_PROJECT_ID=hospira-fc0dc

# FCM push guard (fail-closed: prazna lista = nema slanja)
FCM_PUSH_ENABLED=true
FCM_PUSH_ALLOWED_TENANT_SLUGS=demo,uzorita,channex

# Outbound email (guest booking confirmation / refusal)
# Per-tenant SMTP credentials are configured in Django admin:
# Tenants → Reception settings → guest_contact_email + Guest SMTP password.
# Host is derived automatically as mail.{domain from email} (port 587, TLS).
# Optional global fallback if tenant SMTP is not set:
# EMAIL_HOST=mail.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@stay.hr

# Guest message compose (LLM — Channex / Booking.com odgovori; reception POST .../messages/compose/)
# GUEST_COMPOSE_LLM_PROVIDER=openai
# GUEST_COMPOSE_LLM_API_KEY=sk-proj-...
# GUEST_COMPOSE_LLM_MODEL=gpt-4o-mini
# GUEST_COMPOSE_LLM_TIMEOUT_SEC=30
# GUEST_COMPOSE_PROMPT_VERSION=v1

# Document OCR (WhatsApp share / batch intake — OpenAI Vision)
# DOCUMENT_OCR_LLM_PROVIDER=openai
# DOCUMENT_OCR_LLM_API_KEY=sk-proj-...   # optional; falls back to GUEST_COMPOSE_LLM_API_KEY
# DOCUMENT_OCR_LLM_MODEL=gpt-4o
# DOCUMENT_OCR_LLM_TIMEOUT_SEC=90
# DOCUMENT_OCR_PROMPT_VERSION=v1

# Redis / Celery (shared infra-redis — /opt/stacks/redis, DB 2)
REDIS_URL=redis://infra-redis:6379/2
CELERY_BROKER_URL=redis://infra-redis:6379/2
CELERY_RESULT_BACKEND=redis://infra-redis:6379/2
